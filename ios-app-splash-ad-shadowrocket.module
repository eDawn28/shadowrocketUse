[URL Rewrite]
# 网易云音乐
^https?:\/\/interface\.music\.163\.com\/eapi\/ad\/config\/get _ REJECT-DICT

# 知乎
^https?:\/\/api\.zhihu\.com\/commercial_api\/(real_time_)?launch_v2\? _ REJECT-DICT

# Bilibili
^https?:\/\/app\.bilibili\.com\/x\/v2\/splash\/(event\/list|brand\/list|show|list) _ REJECT-DICT

# 高德地图
^https?:\/\/m5\.amap\.com\/ws\/(feature\/preheat\/bootevent|shield\/dsp\/app\/startup\/init|valueadded\/alimama\/splash_screen) _ REJECT-DICT

# 京东
^https?:\/\/api\.m\.jd\.com\/client\.action\?functionId=(lite_advertising|homeAreaPop) _ REJECT-DICT
^https?:\/\/m\.360buyimg\.com\/mobilecms\/s1125 _ REJECT-200
^https?:\/\/(img\w|kjimg10)\.360buyimg\.com\/(pop|mcmktresadmin)\/jfs\/.*\.(jpg|png|heic|webp|avif) _ REJECT-200

# 淘宝 / 天猫 / 闲鱼 / 飞猪 / 阿里系
^https?:\/\/ossgw\.alicdn\.com\/creatives-assets\/(image|prod)\/.*\.(jpg|png|heic|webp) _ REJECT-200
^https?:\/\/cloud\.video\.taobao\.com\/vod\/.*\.mp4 _ REJECT-200
^https?:\/\/cloud\.video\.taobao\.com\/.*alimama.*\.mp4 _ REJECT-VIDEO
^https?:\/\/acs\.m\.goofish\.com\/gw\/mtop\.taobao\.idlecommerce\.splash _ REJECT-DICT
^https?:\/\/acs\.m\.goofish\.com\/gw\/mtop\.idle\.idleadv\..* _ REJECT-DICT
^https?:\/\/img\.alicdn\.com\/imgextra\/i\w\/.*-at.*\.(jpg|png|heic|webp) _ REJECT-200
^https?:\/\/(gw|heic|img)\.alicdn\.com\/imgextra\/i\w\/.*(1080-|1125-|1350|-1602|-1950|-2208|-2339|-2436|1170-2532).*\.(jpg|png|heic|webp) _ REJECT-200

# 58 同城
^https?:\/\/app\.58\.com\/api\/home\/appadv\/splashscreenadv _ REJECT-DICT

# 脉脉
^https?:\/\/open\.taou\.com\/maimai\/adshow _ REJECT-DICT

[MITM]
enable = true
hostname = interface.music.163.com,api.zhihu.com,app.bilibili.com,m5.amap.com,api.m.jd.com,m.360buyimg.com,*.360buyimg.com,ossgw.alicdn.com,cloud.video.taobao.com,acs.m.goofish.com,img.alicdn.com,gw.alicdn.com,heic.alicdn.com,app.58.com,open.taou.com
